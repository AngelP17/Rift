# Rift Configuration
# Copy to .env and adjust as needed

# Data generation
RIFT_SEED=42
RIFT_FRAUD_RATE=0.02

# Model paths
RIFT_MODEL_DIR=./artifacts/models
RIFT_AUDIT_DB=./artifacts/audit.duckdb
RIFT_MLFLOW_URI=./artifacts/mlruns

# API
RIFT_API_HOST=0.0.0.0
RIFT_API_PORT=8000

# Logging
RIFT_LOG_LEVEL=INFO

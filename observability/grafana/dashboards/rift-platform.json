{
  "dashboard": {
    "title": "Rift Platform Overview",
    "uid": "rift-platform",
    "tags": ["rift", "fraud-detection"],
    "timezone": "utc",
    "refresh": "30s",
    "time": {"from": "now-1h", "to": "now"},
    "panels": [
      {
        "title": "API Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{"expr": "rate(rift_api_requests_total[5m])", "legendFormat": "{{method}} {{endpoint}}"}]
      },
      {
        "title": "API Latency (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [{"expr": "histogram_quantile(0.95, rate(rift_api_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"}]
      },
      {
        "title": "Latest PR-AUC",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 8},
        "targets": [{"expr": "rift_latest_pr_auc"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 0.7, "color": "yellow"}, {"value": 0.85, "color": "green"}]}}}
      },
      {
        "title": "Latest ECE",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 8},
        "targets": [{"expr": "rift_latest_ece"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.05, "color": "yellow"}, {"value": 0.1, "color": "red"}]}}}
      },
      {
        "title": "Latest Brier Score",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 8},
        "targets": [{"expr": "rift_latest_brier_score"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.12, "color": "yellow"}, {"value": 0.2, "color": "red"}]}}}
      },
      {
        "title": "Training Runs",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 8},
        "targets": [{"expr": "rift_training_runs_total"}]
      },
      {
        "title": "Predictions Recorded",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 8},
        "targets": [{"expr": "rift_predictions_recorded_total"}]
      },
      {
        "title": "Fairness Audits",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 8},
        "targets": [{"expr": "rift_fairness_audits_total"}]
      },
      {
        "title": "ETL Pipeline Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {"expr": "rate(rift_etl_runs_total[5m])", "legendFormat": "runs/s"},
          {"expr": "rate(rift_etl_rows_loaded_total[5m])", "legendFormat": "rows loaded/s"}
        ]
      },
      {
        "title": "ETL Duration (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [{"expr": "histogram_quantile(0.95, rate(rift_etl_duration_seconds_bucket[5m]))", "legendFormat": "p95 seconds"}]
      },
      {
        "title": "Drift Score Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [{"expr": "rift_latest_drift_score", "legendFormat": "drift score"}]
      },
      {
        "title": "Drift Detections",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 20},
        "targets": [{"expr": "rift_drift_detected_total"}]
      },
      {
        "title": "Demographic Parity Difference",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 20},
        "targets": [{"expr": "rift_fairness_demographic_parity_difference"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.1, "color": "yellow"}, {"value": 0.2, "color": "red"}]}, "max": 1}}
      },
      {
        "title": "NL Query Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "targets": [
          {"expr": "rate(rift_nl_queries_total[5m])", "legendFormat": "total"},
          {"expr": "rate(rift_nl_query_llm_used_total[5m])", "legendFormat": "LLM"},
          {"expr": "rate(rift_nl_query_fallback_used_total[5m])", "legendFormat": "fallback"}
        ]
      },
      {
        "title": "NL Query Latency (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "targets": [{"expr": "histogram_quantile(0.95, rate(rift_nl_query_duration_seconds_bucket[5m]))", "legendFormat": "p95"}]
      }
    ]
  },
  "overwrite": true
}
